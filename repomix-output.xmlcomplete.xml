<file path="frontend/src/styles/responsive.module.css">
/*
 * responsive.module.css
 *
 * Exclusively handles responsive layout behaviour.
 * Rules are purely additive — no colour, typography, border, shadow or
 * component-visual styles are redefined here.
 *
 * Breakpoints (mirrors Tailwind defaults):
 *   mobile  : < 640 px   (no prefix)
 *   sm      : 640 – 767 px
 *   md      : 768 – 1023 px
 *   lg      : ≥ 1024 px   (desktop — default visible-sidebar layout)
 */

/* ─────────────────────────────────────────────────────────────────────────────
   SIDEBAR
   Desktop  : sticky in flow, always visible.
   < 1024px : fixed overlay, slides in from the left when open.
───────────────────────────────────────────────────────────────────────────── */

.sidebar {
  /* Own the position on all breakpoints so Tailwind's `.sticky` is not needed */
  position: sticky;
  top: 0;
  /* Smooth slide for mobile open/close */
  transition: transform 0.26s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ─────────────────────────────────────────────────────────────────────────────
   OVERLAY  (mobile backdrop behind the open sidebar)
   Hidden by default; revealed via JS toggle on narrow viewports.
───────────────────────────────────────────────────────────────────────────── */

.overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 30;
  background-color: rgba(15, 23, 42, 0.45);
  cursor: pointer;
}

/* ─────────────────────────────────────────────────────────────────────────────
   HAMBURGER BUTTON  (lives in Topbar, hidden on desktop)
───────────────────────────────────────────────────────────────────────────── */

.menuBtn {
  display: none;
  flex-shrink: 0;
  align-items: center;
  justify-content: center;
  padding: 0.375rem;
  border-radius: 0.5rem;
  border: none;
  background: transparent;
  color: white;
  cursor: pointer;
  transition: background-color 0.15s ease;
}

.menuBtn:hover {
  background-color: rgba(255, 255, 255, 0.18);
}

/* ─────────────────────────────────────────────────────────────────────────────
   PAGE CONTENT INNER  (applied to the per-page scrollable div)
   Reduces horizontal padding on small screens so content has breathing room.
   Desktop padding is controlled by Tailwind (p-6 pb-10/pb-12) on the element.
───────────────────────────────────────────────────────────────────────────── */

/* ═════════════════════════════════════════════════════════════════════════════
   RESPONSIVE OVERRIDES
   All layout changes are scoped to their respective breakpoints.
═════════════════════════════════════════════════════════════════════════════ */

/* ── Tablet & mobile  (< 1024px) ── */
@media (max-width: 1023px) {
  /* Sidebar becomes a fixed slide-over panel */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    z-index: 40;
    transform: translateX(-100%);
  }

  /* Sidebar open state — applied by JS when the menu is toggled */
  .sidebarOpen {
    transform: translateX(0);
  }

  /* Backdrop visible when sidebar is open */
  .overlay {
    display: block;
  }

  /* Show hamburger button */
  .menuBtn {
    display: flex;
  }
}

/* ── Mobile  (< 640px) ── */
@media (max-width: 639px) {
  /* Tighter horizontal padding so content doesn't feel cramped */
  .pageContent {
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  /* Stats grid: single column on tiny screens */
  .statsGrid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* ── Small mobile  (< 400px) ── */
@media (max-width: 399px) {
  .statsGrid {
    grid-template-columns: 1fr;
  }
}
