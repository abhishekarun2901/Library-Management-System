                  ]
                }
              }
            },
            {
              "name": "Cancel Latest Reservation",
              "request": {
                "method": "DELETE",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/reservations/{{memberReservationId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "reservations",
                    "{{memberReservationId}}"
                  ]
                }
              }
            },
            {
              "name": "Admin Issues Copy To Member (uses existing copy)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{adminToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"userId\": \"{{memberUserId}}\",\n  \"copyId\": \"{{availableCopyId}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/transactions",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "transactions"
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Issue copy status', function () { pm.expect(pm.response.code).to.be.oneOf([201, 400, 401, 403]); });",
                      "if (pm.response.code === 201) {",
                      "  const data = pm.response.json();",
                      "  if (data.transactionId) pm.environment.set('memberTxId', data.transactionId);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "View Own Transactions",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/transactions",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "transactions"
                  ]
                }
              }
            },
            {
              "name": "Return Latest Transaction",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"RETURNED\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/transactions/{{memberTxId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "transactions",
                    "{{memberTxId}}"
                  ]
                }
              }
            },
            {
              "name": "Mark Latest Transaction LOST",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"LOST\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/transactions/{{memberTxId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "transactions",
                    "{{memberTxId}}"
                  ]
                }
              }
            }
          ]
        },
        {
          "name": "Notifications And Fines",
          "item": [
            {
              "name": "View Own Fines",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/users?scope=fines",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "users"
                  ],
                  "query": [
                    {
                      "key": "scope",
                      "value": "fines"
                    }
                  ]
                }
              }
            },
            {
              "name": "View Notifications",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/notifications",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "notifications"
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Notifications status', function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]); });",
                      "if (pm.response.code === 200) {",
                      "  const list = pm.response.json();",
                      "  if (Array.isArray(list) && list.length > 0 && list[0].notificationId) {",
                      "    pm.environment.set('memberNotificationId', list[0].notificationId);",
                      "  }",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Mark First Notification Read",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{memberToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/notifications/{{memberNotificationId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "notifications",
                    "{{memberNotificationId}}"
                  ]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
