<file path="docs/postman/LBMS_E2E.postman_collection.json">
{
  "info": {
    "name": "LBMS Role-Based Existing DB",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Role-organized collection (Admin/Member). Request bodies use IDs discovered from existing DB records via API calls."
  },
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login Admin",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/v1/auth/login",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "auth",
                    "login"
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Admin login status', function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]); });",
                      "if (pm.response.code === 200) {",
                      "  const data = pm.response.json();",
                      "  if (data.token) pm.environment.set('adminToken', data.token);",
                      "  if (data.userId) pm.environment.set('adminUserId', data.userId);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get Admin Profile (scope=me)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{adminToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/users?scope=me",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "users"
                  ],
                  "query": [
                    {
                      "key": "scope",
                      "value": "me"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Admin profile status', function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403]); });",
                      "if (pm.response.code === 200) {",
                      "  const data = pm.response.json();",
                      "  if (data.userId) pm.environment.set('adminUserId', data.userId);",
                      "}"
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "name": "Catalog",
          "item": [
            {
              "name": "List Books (save existingBookId)",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{baseUrl}}/v1/books?page=0&size=20&sortBy=title",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "books"
                  ],
                  "query": [
                    {
                      "key": "page",
                      "value": "0"
                    },
                    {
                      "key": "size",
                      "value": "20"
                    },
                    {
                      "key": "sortBy",
                      "value": "title"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('List books status', function () { pm.response.to.have.status(200); });",
                      "const data = pm.response.json();",
                      "const books = Array.isArray(data) ? data : (data.content || []);",
                      "pm.test('Books found', function () { pm.expect(books.length).to.be.above(0); });",
                      "if (books.length > 0) {",
                      "  const b = books.find(x => x.isActive !== false) || books[0];",
                      "  if (b.bookId) pm.environment.set('existingBookId', b.bookId);",
                      "  if (b.title) pm.environment.set('existingBookTitle', b.title);",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Get Copies By Existing Book (save availableCopyId)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{adminToken}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/v1/copies?book_id={{existingBookId}}",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "v1",
                    "copies"
                  ],
                  "query": [
                    {
                      "key": "book_id",
                      "value": "{{existingBookId}}"
                    }
                  ]
                }
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test('Get copies status', function () { pm.expect(pm.response.code).to.be.oneOf([200, 401, 403, 404]); });",
                      "if (pm.response.code === 200) {",
                      "  const copies = pm.response.json();",
                      "  if (Array.isArray(copies) && copies.length > 0) {",
                      "    pm.environment.set('existingCopyId', copies[0].copyId);",
                      "    const available = copies.find(c => (c.status || '').toUpperCase() === 'AVAILABLE');",
                      "    if (available && available.copyId) pm.environment.set('availableCopyId', available.copyId);",
                      "  }",
                      "}"
                    ]
                  }
                }
              ]
            },
            {
              "name": "Search By ISBN (optional var)",
              "request": {
