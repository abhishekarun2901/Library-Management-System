# ── Maven build output ────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Compiled class files ──────────────────────────────────────────────────────
*.class

# ── Package files ─────────────────────────────────────────────────────────────
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ── Virtual machine crash logs ────────────────────────────────────────────────
hs_err_pid*
replay_pid*

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
.classpath
.project
.settings/
.springBeans
.sts4-cache

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.properties.local

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
