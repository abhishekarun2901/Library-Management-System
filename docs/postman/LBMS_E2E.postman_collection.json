                      "    const adminId = pm.environment.get('adminUserId');",
                      "    const target = users.find(u => u.userId !== adminId) || users[0];",
                      "    if (target && target.userId) pm.environment.set('targetUserId', target.userId);",
                      "  }",
                      "}"
