                              ? 'available'
                              : 'issued'
                          }
                        />
                        <Button
                          variant="secondary"
                          className="text-xs"
                          onClick={() => openCopies(book)}
                        >
                          Copies
                        </Button>
                        <Button
                          variant="secondary"
                          className="text-xs"
                          onClick={() => openEdit(book)}
                        >
                          Edit
                        </Button>
                        <Button
                          variant="secondary"
                          className="text-xs text-red-600 hover:text-red-700"
                          onClick={() => openDeleteBook(book)}
                        >
                          Delete
                        </Button>
                      </div>
                    }
                  />
                ))}
